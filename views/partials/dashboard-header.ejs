                <div class="list-group list-group-flush border-0">
                    <a href="/dashboard" class="list-group-item list-group-item-action border-0 py-3 rounded-2 mb-1 <%= typeof currentPage !== 'undefined' && currentPage === 'dashboard' ? 'bg-primary text-white active' : 'text-secondary' %>">
