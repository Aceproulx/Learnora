<style>
    /* Remove grey highlight from navbar toggler */
    .navbar-toggler:focus,
    .navbar-toggler:active,
    .navbar-toggler:hover {
        outline: none;
        box-shadow: none;
        border: none;
    }

    /* Compact Mobile Navbar */
    @media (max-width: 991.98px) {
        .navbar-brand h2 {
            font-size: 1.3rem !important;
        }
        nav.navbar > div.d-flex {
            padding: 10px 15px !important;
        }
    }
</style>
<script id="firebase-config" type="application/json"><%- JSON.stringify(firebaseConfig) %></script>

<script>
    (function() {
        const firebaseConfig = JSON.parse(document.getElementById('firebase-config').textContent);
        if (!firebase.apps.length) firebase.initializeApp(firebaseConfig);
        const auth = firebase.auth();
        const db = firebase.database();
        const cartBadge = document.getElementById('cart-badge-dash');

        function updateCartBadge(uid) {
            db.ref('users/' + uid + '/cart').on('value', (snapshot) => {
                const cart = snapshot.val();
                if (cart && cartBadge) {
                    const count = Object.keys(cart).length;
                    cartBadge.innerText = count;
                    cartBadge.style.display = 'block';
                } else if (cartBadge) {
                    cartBadge.style.display = 'none';
                }
            });
        }

        auth.onAuthStateChanged(user => {
            if (user) {
                updateCartBadge(user.uid);
                
                // Update Name
                const updateUI = (name) => {
                    if (document.getElementById('userName')) document.getElementById('userName').innerText = name;
                    if (document.getElementById('userNameMobile')) document.getElementById('userNameMobile').innerText = name;
                };

                // Fallback to Auth Display Name immediately
                if (user.displayName) updateUI(user.displayName);
                
                // Then try to get from Database Profile (more accurate)
                db.ref('users/' + user.uid + '/profile').on('value', snapshot => {
                    const profile = snapshot.val();
                    if (profile && profile.displayName) {
                        updateUI(profile.displayName);
                    }
                });
            }
        });

    })();
</script>
<!-- Navbar End -->