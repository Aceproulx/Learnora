                    <a href="/payment-history" class="list-group-item list-group-item-action border-0 py-3 rounded-2 mb-1 <%= typeof currentPage !== 'undefined' && currentPage === 'payments' ? 'bg-primary text-white active' : 'text-secondary' %>">
