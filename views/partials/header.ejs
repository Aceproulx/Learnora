<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8">
    <title><%= title %> | Learnora</title>
    <meta content="width=device-width, initial-scale=1.0" name="viewport">
    <meta content="" name="keywords">
    <meta content="" name="description">

    <!-- Learnora logo -->
    <link rel="icon" href="/img/Learnora-logo.png" type="image/png">

    <!-- Google Web Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Heebo:wght@400;500;600&family=Nunito:wght@600;700;800&display=swap"
        rel="stylesheet">

    <!-- Icon Font Stylesheet -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.10.0/css/all.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.4.1/font/bootstrap-icons.css" rel="stylesheet">

    <!-- Libraries Stylesheet -->
    <link href="/lib/animate/animate.min.css" rel="stylesheet">
    <link href="/lib/owlboolene/assets/owl.boolene.min.css" rel="stylesheet">

    <!-- Customized Bootstrap Stylesheet -->
    <link href="/css/bootstrap.min.css" rel="stylesheet">

    <!-- page Stylesheet -->
    <link href="/css/style.css" rel="stylesheet">
</head>

<body>


    <!-- Navbar Start -->
    <nav class="navbar navbar-expand-xl bg-white navbar-light shadow sticky-top p-0">
        <a href="/" class="navbar-brand d-flex align-items-center px-4 px-lg-5">
            <h2 class="m-0 text-primary"><i class="fa fa-book me-3"></i>Learnora-acadamy</h2>
        </a>
        <button type="button" class="navbar-toggler me-4" data-bs-toggle="collapse" data-bs-target="#navbarCollapse">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarCollapse">
            <div class="navbar-nav ms-auto p-4 p-xl-0">
                <a href="/" class="nav-item nav-link <%= currentPage === 'home' ? 'active' : '' %>">Home</a>
                <a href="/about" class="nav-item nav-link <%= currentPage === 'about' ? 'active' : '' %>">About</a>
                <a href="/courses" class="nav-item nav-link <%= currentPage === 'courses' ? 'active' : '' %>">Courses</a>
                <a href="/contact" class="nav-item nav-link <%= currentPage === 'contact' ? 'active' : '' %>">Contact</a>
                <a href="/cart" class="nav-item nav-link position-relative px-3 <%= currentPage === 'cart' ? 'active' : '' %>">
                    <i class="fa fa-shopping-cart fs-5"></i>
                    <span id="cart-badge" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="display: none; font-size: 10px; margin-top: 15px;">
                        0
                    </span>
                </a>
            </div>
            <div id="nav-auth-buttons" class="px-4 px-xl-0 pb-4 pb-xl-0">
                <!-- Join Now Button -->
                <a href="/auth" id="join-now-btn" class="btn btn-primary py-2 py-xl-4 px-lg-5 d-block">Join Now<i
                        class="fa fa-arrow-right ms-3"></i></a>
                
                <!-- Dashboard Button -->
                <a href="/dashboard" id="dashboard-btn" class="btn btn-primary py-2 py-xl-4 px-lg-5 d-block" style="display: none !important;">Dashboard<i
                        class="fa fa-user ms-3"></i></a>
            </div>
        </div>
    </nav>
    <!-- Navbar End -->

    <!-- Firebase SDK (v9 compat) -->
    <script src="https://www.gstatic.com/firebasejs/9.22.0/firebase-app-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/9.22.0/firebase-auth-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/9.22.0/firebase-database-compat.js"></script>

    <script>
        (function() {
            // Configuration injected from the server
            const firebaseConfig = JSON.parse('<%- JSON.stringify(firebaseConfig) %>');
            
            // Initialize Firebase if not already initialized
            if (!firebase.apps.length) {
                firebase.initializeApp(firebaseConfig);
            }
            
            const auth = firebase.auth();
            const joinBtn = document.getElementById('join-now-btn');
            const dashBtn = document.getElementById('dashboard-btn');
            const cartBadge = document.getElementById('cart-badge');

            // --- CART BADGE LOGIC ---
            function updateCartBadge(uid) {
                if (!firebase.apps.length) return;
                firebase.database().ref('users/' + uid + '/cart').on('value', (snapshot) => {
                    const cart = snapshot.val();
                    if (cart && cartBadge) {
                        const count = Object.keys(cart).length;
                        cartBadge.innerText = count;
                        cartBadge.style.display = 'block';
                    } else if (cartBadge) {
                        cartBadge.style.display = 'none';
                    }
                });
            }

            // --- FLICKER PREVENTION: Immediate UI update from Cache ---
            const cachedState = localStorage.getItem('learnora_auth_state');
            if (cachedState === 'in') {
                if (joinBtn) joinBtn.setAttribute('style', 'display: none !important;');
                if (dashBtn) dashBtn.setAttribute('style', 'display: block !important;');
            } else if (cachedState === 'out') {
                if (joinBtn) joinBtn.setAttribute('style', 'display: block !important;');
                if (dashBtn) dashBtn.setAttribute('style', 'display: none !important;');
            }

            auth.onAuthStateChanged((user) => {
                if (user) {
                    // Update Cache
                    localStorage.setItem('learnora_auth_state', 'in');
                    // User is signed in
                    if (joinBtn) joinBtn.setAttribute('style', 'display: none !important;');
                    if (dashBtn) dashBtn.setAttribute('style', 'display: block !important;');
                    updateCartBadge(user.uid);
                } else {
                    // Update Cache
                    localStorage.setItem('learnora_auth_state', 'out');
                    // User is signed out
                    if (joinBtn) joinBtn.setAttribute('style', 'display: block !important;');
                    if (dashBtn) dashBtn.setAttribute('style', 'display: none !important;');
                    if (cartBadge) cartBadge.style.display = 'none';
                }
            });

            // --- ENROLLMENT AUTH INTERCEPTOR ---
            document.addEventListener('click', (e) => {
                const target = e.target.closest('a');
                if (target && target.getAttribute('href') && target.getAttribute('href').startsWith('/payment')) {
                    if (!auth.currentUser) {
                        e.preventDefault();
                        const dest = target.getAttribute('href');
                        // Optional: Store the destination so we can redirect back after login
                        localStorage.setItem('redirect_after_auth', dest);
                        window.location.href = '/auth';
                    }
                }
            });
        })();
    </script>
