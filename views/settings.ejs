<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8">
    <title><%= title %> | Learnora</title>
    <meta content="width=device-width, initial-scale=1.0" name="viewport">
    <meta content="" name="keywords">
    <meta content="" name="description">

    <!-- Favicon -->
    <link rel="icon" href="/img/Learnora-logo.png" type="image/png">

    <!-- Google Web Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Heebo:wght@400;500;600&family=Nunito:wght@600;700;800&display=swap"
        rel="stylesheet">

    <!-- Icon Font Stylesheet -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.10.0/css/all.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.4.1/font/bootstrap-icons.css" rel="stylesheet">

    <!-- Libraries Stylesheet -->
    <link href="/lib/animate/animate.min.css" rel="stylesheet">
    <link href="/lib/owlLearnora/assets/owl.Learnora.min.css" rel="stylesheet">

    <!-- Customized Bootstrap Stylesheet -->
    <link href="/css/bootstrap.min.css" rel="stylesheet">

    <!-- Template Stylesheet -->
    <link href="/css/style.css" rel="stylesheet">

    <style>
        :root {
            --primary: #06BBCC;
            --secondary: #181d38;
            --light-bg: #f0f4f8;
        }

        body {
            background-color: var(--light-bg);
        }

        /* Sidebar Styling (from dashboard) */
        .sidebar {
            min-width: 250px;
            max-width: 250px;
            background: var(--secondary);
            color: #fff;
            transition: all 0.3s;
            min-height: calc(100vh - 75px);
        }

        .sidebar .nav-link {
            color: rgba(255, 255, 255, 0.7);
            padding: 15px 25px;
            font-weight: 500;
            transition: 0.3s;
            border-left: 3px solid transparent;
        }

        .sidebar .nav-link:hover,
        .sidebar .nav-link.active {
            color: #fff;
            background: rgba(255, 255, 255, 0.1);
            border-left: 3px solid var(--primary);
        }

        .sidebar .nav-link i {
            margin-right: 10px;
        }

        /* Content Area */
        .content-area {
            flex: 1;
            padding: 40px 20px;
            background-color: #f8fafc;
        }

        .settings-header {
            margin-bottom: 30px;
        }

        .settings-header h2 {
            font-weight: 800;
            color: var(--secondary);
            margin-bottom: 10px;
        }

        .settings-card {
            background: #fff;
            border-radius: 20px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
            border: 1px solid rgba(0,0,0,0.05);
            overflow: hidden;
            margin-bottom: 30px;
        }

        .card-section-title {
            padding: 25px 30px;
            background: #fcfcfc;
            border-bottom: 1px solid #f0f0f0;
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .card-section-title i {
            color: var(--primary);
            font-size: 1.2rem;
        }

        .card-section-title h5 {
            margin: 0;
            font-weight: 700;
            color: var(--secondary);
        }

        .card-content {
            padding: 30px;
        }

        .profile-upload-section {
            display: flex;
            align-items: center;
            gap: 25px;
            margin-bottom: 40px;
        }

        .profile-avatar-wrapper {
            position: relative;
            width: 100px;
            height: 100px;
        }

        .profile-avatar {
            width: 100%;
            height: 100%;
            border-radius: 25px;
            object-fit: cover;
            border: 3px solid #fff;
            box-shadow: 0 8px 20px rgba(0,0,0,0.1);
        }

        .avatar-badge {
            position: absolute;
            bottom: -5px;
            right: -5px;
            background: var(--primary);
            color: #fff;
            width: 30px;
            height: 30px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            border: 3px solid #fff;
            font-size: 0.8rem;
        }

        .form-label {
            font-weight: 600;
            color: #64748b;
            font-size: 0.85rem;
            margin-bottom: 8px;
            display: block;
        }

        .input-group-modern {
            position: relative;
            margin-bottom: 20px;
        }

        .input-group-modern i {
            position: absolute;
            left: 18px;
            top: 50%;
            transform: translateY(-50%);
            color: #94a3b8;
            transition: 0.3s;
        }

        .form-control-modern {
            padding: 14px 14px 14px 48px;
            border-radius: 12px;
            border: 1.5px solid #e2e8f0;
            font-weight: 500;
            color: #1e293b;
            transition: 0.3s;
            width: 100%;
        }

        .form-control-modern:focus {
            border-color: var(--primary);
            box-shadow: 0 0 0 4px rgba(6, 187, 204, 0.1);
            outline: none;
        }

        .form-control-modern:focus + i {
            color: var(--primary);
        }

        .form-control-modern:disabled {
            background-color: #f1f5f9;
            color: #94a3b8;
        }

        .btn-save-modern {
            background: var(--primary);
            color: #fff;
            border: none;
            padding: 16px 40px;
            border-radius: 12px;
            font-weight: 700;
            transition: 0.3s;
            box-shadow: 0 4px 15px rgba(6, 187, 204, 0.3);
        }

        .btn-save-modern:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(6, 187, 204, 0.4);
            background: #05a8b9;
        }

        @media (max-width: 768px) {
            .profile-upload-section {
                flex-direction: column;
                text-align: center;
                gap: 15px;
            }
            .content-area {
                padding: 20px 15px;
            }
            .card-content {
                padding: 20px;
            }
        }
    </style>
</head>

<body>
    <!-- Spinner End -->

    <!-- Firebase SDKs (Required by headers) -->
    <script src="https://www.gstatic.com/firebasejs/9.22.0/firebase-app-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/9.22.0/firebase-auth-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/9.22.0/firebase-database-compat.js"></script>

    <!-- Dashboard Header -->
    <%- include('partials/dashboard-header', { currentPage: 'settings' }) %>

    <div class="d-flex">
        <!-- Sidebar Start -->
        <%- include('partials/dashboard-sidebar', { currentPage: 'settings' }) %>
        <!-- Sidebar End -->

        <!-- Content Area Start -->
        <div class="content-area">
            <div class="container">
                <div class="settings-header">
                    <h2>Account Settings</h2>
                    <p class="text-muted">Manage your personal information and security settings.</p>
                </div>

                <form id="settingsForm">
                    <!-- Personal Info Card -->
                    <div class="settings-card">
                        <div class="card-section-title">
                            <i class="fa fa-user-circle"></i>
                            <h5>Personal Information</h5>
                        </div>
                        <div class="card-content">
                            <div class="profile-upload-section">
                                <div class="profile-avatar-wrapper">
                                    <img src="/img/default.png" alt="Profile" class="profile-avatar" id="profileImg">
                                    <div class="avatar-badge">
                                        <i class="fa fa-camera"></i>
                                    </div>
                                </div>
                                <div>
                                    <h6 class="mb-1 fw-bold">Profile Picture</h6>
                                    <p class="text-muted small mb-0">PNG, JPG or GIF. Max size of 800K</p>
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-md-6">
                                    <label class="form-label">First Name</label>
                                    <div class="input-group-modern">
                                        <input type="text" class="form-control-modern" id="firstName" placeholder="e.g. John">
                                        <i class="fa fa-user"></i>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Last Name</label>
                                    <div class="input-group-modern">
                                        <input type="text" class="form-control-modern" id="lastName" placeholder="e.g. Doe">
                                        <i class="fa fa-user"></i>
                                    </div>
                                </div>
                                <div class="col-12">
                                    <label class="form-label">Email Address</label>
                                    <div class="input-group-modern">
                                        <input type="email" class="form-control-modern" id="email" placeholder="email@example.com">
                                        <i class="fa fa-envelope"></i>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Password Card -->
                    <div class="settings-card">
                        <div class="card-section-title">
                            <i class="fa fa-shield-alt"></i>
                            <h5>Security & Password</h5>
                        </div>
                        <div class="card-content">
                            <div class="row">
                                <div class="col-md-6">
                                    <label class="form-label">New Password</label>
                                    <div class="input-group-modern">
                                        <input type="password" class="form-control-modern" id="newPassword" placeholder="••••••••">
                                        <i class="fa fa-lock"></i>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Confirm New Password</label>
                                    <div class="input-group-modern">
                                        <input type="password" class="form-control-modern" id="confirmPassword" placeholder="••••••••">
                                        <i class="fa fa-shield-alt"></i>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Account Actions Card -->
                    <div class="settings-card border-danger" style="border-width: 1px; background-color: #fff5f5;">
                        <div class="card-section-title" style="background: #fffafa;">
                            <i class="fa fa-door-open text-danger"></i>
                            <h5 class="text-danger">Account Actions</h5>
                        </div>
                        <div class="card-content d-flex justify-content-between align-items-center flex-wrap gap-3">
                            <div>
                                <h6 class="mb-1 fw-bold">Sign Out</h6>
                                <p class="text-muted small mb-0">Securely log out of your Learnora account.</p>
                            </div>
                            <button type="button" class="btn btn-outline-danger px-4 py-2 fw-bold" id="logoutBtn" style="border-radius: 10px;">
                                <i class="fa fa-sign-out-alt me-2"></i> Logout
                            </button>
                        </div>
                    </div>

                    <div class="text-end mb-5">
                        <button type="submit" class="btn-save-modern">
                            <i class="fa fa-save me-2"></i> Save All Changes
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Footer Start -->
    <div class="container-fluid bg-dark text-light footer pt-5 mt-5">
        <div class="container py-5">
            <div class="row g-5">
                <div class="col-lg-3 col-md-6">
                    <h4 class="text-white mb-3">Quick Link</h4>
                    <a class="btn btn-link" href="/about">About Us</a>
                    <a class="btn btn-link" href="/contact">Contact Us</a>
                </div>
                <div class="col-lg-3 col-md-6">
                    <h4 class="text-white mb-3">Contact</h4>
                    <p class="mb-2"><i class="fa fa-envelope me-3"></i>support@learnora.com</p>
                    <div class="d-flex pt-2">
                        <a class="btn btn-outline-light btn-social" href=""><i class="fab fa-whatsapp"></i></a>
                        <a class="btn btn-outline-light btn-social" href=""><i class="fab fa-facebook-f"></i></a>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- Footer End -->

    <!-- Back to Top -->
    <a href="#" class="btn btn-lg btn-primary btn-lg-square back-to-top"><i class="bi bi-arrow-up"></i></a>

    <!-- JavaScript Libraries -->
    <script src="https://code.jquery.com/jquery-3.4.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/lib/wow/wow.min.js"></script>
    <script src="/lib/easing/easing.min.js"></script>
    <script src="/lib/waypoints/waypoints.min.js"></script>
    <script src="/lib/owlLearnora/owl.Learnora.min.js"></script>

    <!-- page Javascript -->
    <script src="/js/main.js"></script>

    <script>
        const spinner = document.getElementById('spinner');
        const firebaseConfig = JSON.parse(document.getElementById('firebase-config').textContent);
        if (!firebase.apps.length) firebase.initializeApp(firebaseConfig);
        const auth = firebase.auth();
        const db = firebase.database();

        auth.onAuthStateChanged(user => {
            if (spinner) spinner.classList.remove('show');
            if (user) {
                // Pre-fill fields
                document.getElementById('email').value = user.email || '';
                
                // Try to get profile from DB for more accurate names
                db.ref('users/' + user.uid + '/profile').once('value').then(snapshot => {
                    const profile = snapshot.val();
                    if (profile) {
                        document.getElementById('firstName').value = profile.firstName || '';
                        document.getElementById('lastName').value = profile.lastName || '';
                    } else if (user.displayName) {
                        const names = user.displayName.split(' ');
                        document.getElementById('firstName').value = names[0] || '';
                        document.getElementById('lastName').value = names.slice(1).join(' ') || '';
                    }
                });
            }
        });

        document.getElementById('settingsForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const user = auth.currentUser;
            if (!user) return;

            const fname = document.getElementById('firstName').value;
            const lname = document.getElementById('lastName').value;
            const email = document.getElementById('email').value;
            const newPass = document.getElementById('newPassword').value;
            const confPass = document.getElementById('confirmPassword').value;

            try {
                // Update display name and database profile
                const displayName = `${fname} ${lname}`.trim();
                await user.updateProfile({ displayName });
                await db.ref(`users/${user.uid}/profile`).update({
                    firstName: fname,
                    lastName: lname,
                    displayName: displayName
                });

                // Update email if changed
                if (email && email !== user.email) {
                    await user.updateEmail(email);
                }

                // Update password
                if (newPass) {
                    if (newPass !== confPass) throw new Error('Passwords do not match');
                    await user.updatePassword(newPass);
                }

                showNotification('Success', 'Settings updated successfully!', 'success');
            } catch (err) {
                console.error(err);
                if (err.code === 'auth/requires-recent-login') {
                    showNotification('Security', 'Please logout and login again to change sensitive info.', 'hint');
                } else {
                    showNotification('Error', err.message, 'error');
                }
            }
        });

        document.getElementById('logoutBtn').addEventListener('click', () => {
            auth.signOut().then(() => {
                window.location.href = '/';
            });
        });
    </script>
</body>

</html>
